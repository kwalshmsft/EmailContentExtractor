@page "/iris-import"
@using EmailContentExtractor.Services
@inject IrisContentImportService IrisService
@inject FileStorageService FileStorage
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Iris Content Import</PageTitle>

<h1>Iris Content Import</h1>
<p>Upload an XML file exported from Iris Content, populate it with localized email content, and download the updated file for re-import.</p>

@* ─── Step 1: Upload XML ─── *@
<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">① Upload Iris Content XML</h5>
    </div>
    <div class="card-body">
        <p class="text-muted">
            Upload the <code>.xml</code> file exported from Iris Content.
        </p>
        <InputFile OnChange="OnXmlSelected" accept=".xml" class="form-control" />

        @if (uploadError != null)
        {
            <div class="alert alert-danger mt-2">@uploadError</div>
        }
    </div>
</div>

@if (contentInfo != null)
{
    @* ─── Show parsed content items ─── *@
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">📄 Content Items in XML</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>ID</th>
                        <th>Existing Variants</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in contentInfo.Items)
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td><code class="text-muted small">@item.Id</code></td>
                            <td>
                                @foreach (var v in item.ExistingVariants)
                                {
                                    <span class="badge bg-secondary me-1">@v</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ─── Step 2: Select source file ─── *@
    <div class="card mb-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">② Select Source Content</h5>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label fw-bold">Source File</label>
                <select class="form-select" @bind="selectedSource">
                    <option value="">— Select a source file —</option>
                    @foreach (var src in sourceFiles)
                    {
                        var genCount = GetGeneratedCount(src);
                        <option value="@src.FileName">
                            @src.FileName (@(src.Locale ?? "?")) — @genCount localized version(s)
                        </option>
                    }
                </select>
                <div class="form-text">
                    Choose the source HTML file whose localized versions should be added as variants.
                </div>
            </div>

            @if (!string.IsNullOrEmpty(selectedSource))
            {
                <div class="mb-3">
                    <strong>Localized variants to generate:</strong>
                    <div class="mt-1">
                        @{
                            var availableLocales = GetAvailableLocales();
                            var existingCultures = contentInfo.Items
                                .SelectMany(i => i.ExistingVariants)
                                .ToHashSet(StringComparer.OrdinalIgnoreCase);
                        }
                        @foreach (var locale in availableLocales)
                        {
                            if (existingCultures.Contains(locale))
                            {
                                <span class="badge bg-warning text-dark me-1" title="Already exists — will be skipped">
                                    @locale ⚠ exists
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success me-1">@locale ✓ new</span>
                            }
                        }
                        @if (availableLocales.Count == 0)
                        {
                            <span class="text-muted">No localized files found for this source.</span>
                        }
                    </div>
                </div>

                <button class="btn btn-primary btn-lg" @onclick="GenerateImportPackage" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                        <text> Processing...</text>
                    }
                    else
                    {
                        <text>📦 Generate Import Package</text>
                    }
                </button>
            }
        </div>
    </div>
}

@if (errorMessage != null)
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@if (result != null)
{
    <div class="card mb-4">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">③ Download Import Package</h5>
        </div>
        <div class="card-body">
            <div class="alert alert-success py-2">
                <strong>✅ Generated @result.Variants.Count variant(s):</strong>
                @string.Join(", ", result.Variants)
            </div>
            <p class="text-muted">
                The ZIP contains locale-named subfolders ready for Iris Content import.
                Extract the ZIP and point the import tool at the extracted folder.
            </p>
            <button class="btn btn-success btn-lg" @onclick="DownloadZip">
                ⬇ Download ZIP
            </button>
        </div>
    </div>
}

@if (isProcessing)
{
    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
         style="background: rgba(0,0,0,0.3); z-index: 9999;">
        <div class="spinner-border text-light" style="width: 3rem; height: 3rem;" role="status">
            <span class="visually-hidden">Processing...</span>
        </div>
    </div>
}

@code {
    private List<StoredFileInfo> sourceFiles = new();
    private IrisContentInfo? contentInfo;
    private string xmlContent = string.Empty;
    private string xmlFileName = string.Empty;
    private string selectedSource = "";
    private IrisImportResult? result;
    private bool isProcessing;
    private string? uploadError;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        sourceFiles = FileStorage.GetAllSources();
    }

    private async Task OnXmlSelected(InputFileChangeEventArgs e)
    {
        uploadError = null;
        errorMessage = null;
        contentInfo = null;
        result = null;
        selectedSource = "";

        try
        {
            var file = e.File;
            xmlFileName = file.Name;

            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            xmlContent = await reader.ReadToEndAsync();

            contentInfo = IrisService.ParseExport(xmlContent);

            if (contentInfo.Items.Count == 0)
            {
                uploadError = "No ExportedContentItem elements found in the XML file.";
                contentInfo = null;
            }
        }
        catch (Exception ex)
        {
            uploadError = $"Error reading XML file: {ex.Message}";
            contentInfo = null;
        }
    }

    private int GetGeneratedCount(StoredFileInfo source)
    {
        if (source.BaseName == null) return 0;
        return FileStorage.GetAllGenerated()
            .Count(g => g.BaseName != null &&
                        g.BaseName.Equals(source.BaseName, StringComparison.OrdinalIgnoreCase));
    }

    private List<string> GetAvailableLocales()
    {
        if (string.IsNullOrEmpty(selectedSource)) return new();

        var baseName = FileStorageService.ParseBaseName(selectedSource);
        if (baseName == null) return new();

        var locales = new List<string>();

        // Include source locale
        var sourceLocale = FileStorageService.ParseLocale(selectedSource);
        if (sourceLocale != null)
            locales.Add(sourceLocale);

        // Add generated locales
        var generated = FileStorage.GetAllGenerated()
            .Where(g => g.BaseName != null &&
                        g.BaseName.Equals(baseName, StringComparison.OrdinalIgnoreCase) &&
                        g.Locale != null)
            .Select(g => g.Locale!)
            .Distinct(StringComparer.OrdinalIgnoreCase);

        locales.AddRange(generated);
        return locales;
    }

    private void GenerateImportPackage()
    {
        errorMessage = null;
        result = null;
        isProcessing = true;

        try
        {
            if (string.IsNullOrWhiteSpace(xmlContent))
            {
                errorMessage = "No XML file loaded.";
                return;
            }
            if (string.IsNullOrEmpty(selectedSource))
            {
                errorMessage = "Please select a source file.";
                return;
            }

            result = IrisService.GenerateImportZip(xmlContent, xmlFileName, selectedSource);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error generating import package: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task DownloadZip()
    {
        if (result == null) return;

        var zipName = Path.GetFileNameWithoutExtension(xmlFileName) + "_import.zip";
        await JS.InvokeVoidAsync("downloadFile", zipName, "application/zip", result.ZipBytes);
    }
}
